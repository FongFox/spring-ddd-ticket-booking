                </mxCell>
                <mxCell id="21" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;vetautets-controller (REST Layer)&lt;/h1&gt;&lt;p&gt;Nơi client (browser, app, curl) gọi vào.&amp;nbsp;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;Chứa các @RestController — định nghĩa endpoint.&lt;br/&gt;&lt;/span&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;Không xử lý business logic.&lt;br/&gt;&lt;/span&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;Chuyển request xuống Application layer.&lt;/span&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
                    <mxGeometry x="290" y="230" width="450" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="22" value="" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;rotation=-90;" vertex="1" parent="1">
                    <mxGeometry x="-280" y="170" width="120" height="500" as="geometry"/>
                </mxCell>
                <mxCell id="23" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;vetautets-controller (REST Layer)&lt;/h1&gt;&lt;p&gt;Cầu nối giữa Controller và Domain.&lt;br/&gt;Chứa interface + implement của app service.&lt;br/&gt;Điều phối luồng xử lý: nhận lệnh → gọi domain → trả kết quả.&lt;br/&gt;Không chứa business rule — chỉ điều phối.&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
                    <mxGeometry x="-470" y="360" width="470" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="24" value="" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;rotation=-90;" vertex="1" parent="1">
                    <mxGeometry x="-280" y="370" width="120" height="500" as="geometry"/>
                </mxCell>
                <mxCell id="25" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;vetautets-domain (Domain Layer)&lt;/h1&gt;&lt;p&gt;Chứa toàn bộ business rule của hệ thống.&lt;br/&gt;Không phụ thuộc bất kỳ module nào khác.&lt;br/&gt;Gồm: Entity, Enum, Repository interface, Domain Service.&lt;br/&gt;Mọi quyết định nghiệp vụ đều nằm ở đây.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
