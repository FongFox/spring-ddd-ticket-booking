                <mxCell id="19" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;vetautets-start (Entry Point)&lt;/h1&gt;&lt;p&gt;Entry point của ứng dụng.&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;Chứa main() — nơi Spring Boot khởi chạy.&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Không chứa business logic.&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Gom tất cả module lại thành 1 app chạy được.&lt;/span&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
