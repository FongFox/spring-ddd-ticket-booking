                    <mxGeometry x="745" y="305" width="120" height="630" as="geometry"/>
                </mxCell>
                <mxCell id="27" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;vetautets-infrashtructure (Infrashtructure Layer)&lt;/h1&gt;&lt;p&gt;Xử lý mọi thứ liên quan đến kỹ thuật hạ tầng.&lt;br/&gt;Implement Repository interface từ Domain.&lt;br/&gt;Kết nối: Database, Kafka, Redis, external API.&lt;br/&gt;Domain không biết infrastructure tồn tại.&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
